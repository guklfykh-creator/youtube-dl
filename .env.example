# Telegram Bot Token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# GitHub Personal Access Token (needs actions:write permission)
# Create at: https://github.com/settings/tokens/new
# Required scopes: repo (or fine-grained: actions:write + contents:write)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo where the download.yml workflow lives
GH_REPO_OWNER=your_username
GH_REPO_NAME=your_youtube_dl_repo

# Default branch of the repo (usually main or master)
GH_DEFAULT_BRANCH=main

# ============================================================
# MTProto uploader (gotd/td) - for sending files > 50MB
# ============================================================

# Telegram App ID and App Hash (from https://my.telegram.org/apps)
# Required for the uploader to authenticate via MTProto
TG_APP_ID=12345678
TG_APP_HASH=abcdef1234567890abcdef1234567890

# Telegram phone number (for initial --auth authentication)
TG_PHONE=+989123456789

# Session file path (default: session.json)
# After running --auth, base64-encode the session file and add
# as GitHub secret TG_SESSION:
#   base64 session.json
# Then add the output as secret TG_SESSION in repo settings