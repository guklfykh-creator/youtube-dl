# Telegram Bot Token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# GitHub Personal Access Token (needs actions:write permission)
# Create at: https://github.com/settings/tokens/new
# Required scopes: repo (or fine-grained: actions:write + contents:write)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo where the download.yml workflow lives
GH_REPO_OWNER=your_username
GH_REPO_NAME=your_youtube_dl_repo

# Default branch of the repo (usually main or master)
GH_DEFAULT_BRANCH=main